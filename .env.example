# Copy to .env (gitignored) for local dev, and set the same value as a GitHub
# Actions repo secret named VITE_WEB3FORMS_KEY for production builds.
#
# This is the Web3Forms access key the Feedback button submits with. Get a free
# key (no account) at https://web3forms.com — enter your email and it gives you
# a key tied to that address, e.g.:
# VITE_WEB3FORMS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# If left unset, the app still works — the Feedback button falls back to letting
# the user download the report and email it manually.
VITE_WEB3FORMS_KEY=

# Optional alternative: a generic JSON POST endpoint (e.g. a Formspree form URL).
# Only used if VITE_WEB3FORMS_KEY is not set.
# VITE_FEEDBACK_ENDPOINT=
