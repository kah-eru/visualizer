# Copy to .env (gitignored) for local dev, and set the same value as a GitHub
# Actions repo secret named VITE_FEEDBACK_ENDPOINT for production builds.
#
# This is the Formspree form endpoint the Feedback button POSTs to. Create a
# free form at https://formspree.io, then paste its URL here, e.g.:
# VITE_FEEDBACK_ENDPOINT=https://formspree.io/f/abcdwxyz
#
# If left unset, the app still works — the Feedback button falls back to
# letting the user download the report and email it manually.
VITE_FEEDBACK_ENDPOINT=
