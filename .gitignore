# Dependencies
node_modules/

# Vite build output (published to GitHub Pages by the deploy workflow)
dist/

# Test artifacts: coverage report (npm run test:coverage) + Playwright's run output
coverage/
test-results/
playwright-report/

# Local env (holds the feedback endpoint; provided as a CI secret for builds)
.env
.env.local

# Local backup artifact (history is in git)
index.html.bak

# Real controller logs must never be committed (privacy). Synthetic test data
# (Evnt_flow_test.csv) is the only log allowed in the repo.
testmanual.csv
# Real monthly event logs (Evnt_yyyyMM.csv) — keep the synthetic Evnt_flow_test.csv.
Evnt_2*.csv
# Real customer support logs dropped in for local diagnosis (never commit).
Events_test.csv
Events1000.csv

# Baseline's internal protocol spec — local reference only, never publish (this repo is public).
Baseline Protocol Specification - BaseManager Opcodes.md

# Personal presentation prep / study notes — local only, never publish (this repo is public).
PRESENTATION_QA.md

# Local agent planning scratch (Claude Code writes plans here; settings.json below is shared).
.claude/plans/

# Personal (per-machine) Claude Code settings; shared settings live in .claude/settings.json
.claude/settings.local.json
